# Security Configuration (Must be unique and strong)
# Use 'openssl rand -hex 32' to generate keys
SECRET_KEY_ACCESS=your-super-secret-access-key-here
SECRET_KEY_REFRESH=your-super-secret-refresh-key-here
ALGORITHM=HS256

# Token Expiration (Minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=auth_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
